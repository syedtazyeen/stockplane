# Copy to .env and adjust values before running: cp .env.example .env

# PostgreSQL
POSTGRES_USER=stockplane
POSTGRES_PASSWORD=stockplane
POSTGRES_DB=stockplane

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=false
# JSON array of allowed browser origins
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# Frontend
FRONTEND_PORT=5173
# URL the browser uses to reach the API (baked in at build time)
VITE_API_URL=http://localhost:8000/api
